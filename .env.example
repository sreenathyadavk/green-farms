# ==========================================
# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and server/.env
# ==========================================

# ==========================================
# FRONTEND (.env)
# ==========================================
VITE_RAZORPAY_KEY_ID=

# ==========================================
# BACKEND (server/.env)
# ==========================================
PORT=3000
FRONTEND_URL=*

# Razorpay Switch
VERIFY_RAZORPAY=true

# Razorpay Credentials
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Google Sheets Configuration
GOOGLE_SHEET_ID=
# Service account JSON must be on a single line
GOOGLE_SERVICE_ACCOUNT_JSON=
